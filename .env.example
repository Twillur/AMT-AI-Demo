# ── Required ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Optional: LangSmith tracing ───────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=AMT-Demo
LANGCHAIN_API_KEY=ls__...

# ── Optional: Gmail inbox integration ─────────────────────────────────────
# App password (not your regular Gmail password). Generate at:
# myaccount.google.com/apppasswords
GMAIL_ADDRESS=your@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Optional: Flask session security ──────────────────────────────────────
FLASK_SECRET_KEY=change-this-to-a-random-string

# ── Optional: Admin login (defaults: admin / 1234) ─────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=1234
